@app.function(hide_code=True)
def get_data_overview(df: pl.DataFrame, mo) -> mo.Html:
    """Generate data overview HTML"""
    if df.height > 0:
        {% for metric in config.metrics %}
        {% if metric.aggregation == 'count' %}
        metric_{{ loop.index }} = df.height
        {% elif metric.aggregation == 'sum' %}
        metric_{{ loop.index }} = df["{{ metric.column }}"].sum()
        {% elif metric.aggregation == 'mean' %}
        metric_{{ loop.index }} = df["{{ metric.column }}"].mean()
        {% elif metric.aggregation == 'n_unique' %}
        metric_{{ loop.index }} = df["{{ metric.column }}"].n_unique()
        {% endif %}
        {% endfor %}

        overview_html = f"""
        ## {{ config.schema_description }}

        <div style="display: grid; grid-template-columns: repeat({{ config.metrics | length }}, 1fr); gap: 1rem; margin: 2rem 0;">
            {% for metric in config.metrics %}
            <div style="padding: 1rem; background: {{ metric.color }}20; border-radius: 8px; text-align: center;">
