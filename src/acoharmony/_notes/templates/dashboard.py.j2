                    {% endif %}
                </p>
            </div>
            {% endfor %}
        </div>
        """
        return mo.md(overview_html)
    else:
        return mo.md("**No {{ config.schema_name }} data found. Please run the transform first.**")


@app.function(hide_code=True)
def create_filter_controls(df: pl.DataFrame, mo):
    """Create filter controls based on data"""
    if df.height > 0:
        filters = {}

        {% for filter in config.filters %}
        {% if filter.widget_type == 'dropdown' %}
        # {{ filter.label }}
        unique_values = df["{{ filter.column }}"].unique().to_list()
        unique_values = [v for v in unique_values if v is not None]
        filters["{{ filter.column }}"] = mo.ui.dropdown(
            options=["All"] + sorted(unique_values),
            value="All",
            label="{{ filter.label }}"
        )
        {% elif filter.widget_type == 'range_slider' %}
        # {{ filter.label }}
        min_val = df["{{ filter.column }}"].min() or 0
        max_val = df["{{ filter.column }}"].max() or 1000000
        filters["{{ filter.column }}"] = mo.ui.range_slider(
            start=min_val,
            stop=max_val,
            step=(max_val - min_val) / 100,
            value=[min_val, max_val],
            label="{{ filter.label }}"
        )
        {% elif filter.widget_type == 'slider' %}
        # {{ filter.label }}
        filters["{{ filter.column }}"] = mo.ui.slider(
            start={{ filter.params.get('min', 0) }},
            stop={{ filter.params.get('max', 20) }},
            step=1,
            value=0,
            label="{{ filter.label }}"
        )
        {% endif %}
        {% endfor %}

        filter_controls = mo.vstack([
            mo.md("## 🔍 Filter Controls"),
            mo.hstack(list(filters.values()))
        ])

        return {
            "controls": filter_controls,
            **filters
        }
    else:
        return {
            "controls": mo.md("**Filters not available - no data loaded**"),
        }


