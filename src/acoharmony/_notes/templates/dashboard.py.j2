@app.cell(hide_code=True)
def display_{{ table.name }}_table(filters):
    if df_{{ config.schema_name }}.height > 0:
        # Apply filters
        {% for filter in table.filters %}
        {{ filter }}_value = filters.get("{{ filter }}").value if "{{ filter }}" in filters else None
        {% endfor %}

        {{ table.name }}_data = get_{{ table.name }}(
            df_{{ config.schema_name }},
            {% for filter in table.filters %}{{ filter }}={{ filter }}_value if {{ filter }}_value != "All" else None,
            {% endfor %}top_n={{ table.page_size }}
        )

        {{ table.name }}_table = mo.vstack([
            mo.md("## {{ table.title }}"),
            mo.ui.table(
                {{ table.name }}_data.to_dicts(),
                pagination=True,
                page_size={{ table.page_size }}
            )
        ])
    else:
        {{ table.name }}_table = mo.md("**No data to display**")

    return ({{ table.name }}_table,)
