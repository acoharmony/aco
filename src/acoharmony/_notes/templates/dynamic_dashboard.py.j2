@app.function(hide_code=True)
def create_data_explorer_widget(filtered_df, mo):
    """Create interactive data explorer for the filtered dataset."""
    if filtered_df.height == 0:
        return mo.md("**No data available for exploration**")

    # Determine the most recent data based on date columns
    schema_analysis = analyze_schema()
    date_cols = schema_analysis['date_cols']

    # Find the most recent window if date columns exist
    window_info = ""
    if date_cols:
        # Use the first date column to determine recency
        primary_date_col = None
        for col in ['file_date', 'end_date', 'start_date', 'effective_date']:
            if col in date_cols:
                primary_date_col = col
                break

        if not primary_date_col and date_cols:
            primary_date_col = date_cols[0]

        if primary_date_col:
            max_date = filtered_df[primary_date_col].max()
            min_date = filtered_df[primary_date_col].min()

            if max_date and min_date:
                window_info = f"""
                <div style="padding: 0.5rem; background: #EFF6FF; border-left: 4px solid #2563EB; margin: 1rem 0;">
                    <p style="margin: 0; color: #1E40AF; font-size: 0.85rem;">
                        <strong>Observable Window:</strong> {min_date} to {max_date}
                        <br><small>Based on {primary_date_col.replace('_', ' ').title()}</small>
                    </p>
                </div>
                """

    # Limit data for performance
    explorer_data = filtered_df.head(1000)

    # Get suggested columns for initial visualization
    numeric_cols = schema_analysis['numeric_cols']
    categorical_cols = schema_analysis['low_cardinality_cols']

    # Smart defaults for x and y axes
    x_col = None
    y_col = None
    color_col = None

    # Try to find good default columns
    if date_cols:
        x_col = date_cols[0]
    elif categorical_cols:
        x_col = categorical_cols[0]

    # Look for important numeric columns for y-axis
    for col in numeric_cols:
        if any(key in col.lower() for key in ['amount', 'cost', 'spend', 'total']):
            y_col = col
            break

    if not y_col and numeric_cols:
        y_col = numeric_cols[0]

    # Find a good color column
    for col in categorical_cols:
        if any(key in col.lower() for key in ['status', 'type', 'category', 'state']):
            color_col = col
            break

    # Create the data explorer widget
    explorer_widget = mo.ui.data_explorer(
        explorer_data,
        x=x_col,
        y=y_col,
        color=color_col
    )

    return mo.vstack([
        mo.md("## 🔬 Interactive Data Explorer"),
        mo.md(window_info) if window_info else None,
        mo.md(f"*Exploring {explorer_data.height:,} records (limited for performance)*"),
        explorer_widget
    ])


