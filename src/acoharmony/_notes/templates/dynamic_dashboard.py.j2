@app.cell(hide_code=True)
def _(analyze_schema, data_editor, datetime, export_button, filtered_df, mo, pl, tempfile, Path):
    """Handle Excel export when button is clicked."""

    download_link = None

    # Only execute if button has been clicked
    if export_button.value:
        # Create a temporary file for the Excel workbook
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        filename = f"{{ config.schema_name }}_export_{timestamp}.xlsx"
        temp_path = Path(tempfile.gettempdir()) / filename

        try:
            # Polars native Excel export with multiple sheets using a dictionary
            sheets_dict = {}

            # Sheet 1: Main filtered data
            if filtered_df.height > 0:
                sheets_dict["Filtered_Data"] = filtered_df

            # Sheet 2: Edited data (if available)
            if data_editor is not None:
                try:
                    # data_editor.value returns a Polars DataFrame when input was Polars
                    edited_df = data_editor.value
                    if edited_df is not None and hasattr(edited_df, 'height') and edited_df.height > 0:
                        sheets_dict["Edited_Data"] = edited_df
                except:
                    # If there's any issue accessing the edited data, skip it
                    pass

            # Sheet 3: Summary statistics
            schema_analysis = analyze_schema()
            if schema_analysis['numeric_cols']:
                summary_df = filtered_df.select(schema_analysis['numeric_cols'][:20]).describe()
                sheets_dict["Statistics"] = summary_df

            # Sheet 4: Data overview
            overview_data = {
                "Metric": [
                    "Total Records",
                    "Total Columns",
                    "Numeric Columns",
                    "Categorical Columns",
                    "Date Columns",
                    "Null Columns"
                ],
                "Value": [
                    filtered_df.height,
                    filtered_df.width,
                    len(schema_analysis['numeric_cols']),
                    len(schema_analysis['categorical_cols']),
                    len(schema_analysis['date_cols']),
                    len(schema_analysis['nullable_cols'])
                ]
            }
            sheets_dict["Overview"] = pl.DataFrame(overview_data)

            # Write all sheets at once using Polars' native method
            # First DataFrame determines the file path
            first_df = list(sheets_dict.values())[0]
            first_df.write_excel(
                str(temp_path),
                worksheet=list(sheets_dict.keys())[0],
                autofit=True,
                autofilter=True
            )

            # Add remaining sheets if more than one
            if len(sheets_dict) > 1:
                # For multiple sheets, we need to use ExcelWriter context
                with pl.ExcelWriter(str(temp_path), engine="xlsxwriter") as writer:
                    for sheet_name, df in sheets_dict.items():
                        df.write_excel(
                            writer,
                            worksheet=sheet_name,
                            autofit=True,
                            autofilter=(sheet_name == "Filtered_Data")
                        )

            # Create download link
            with open(temp_path, 'rb') as f:
                download_link = mo.download(
                    data=f.read(),
                    filename=filename,
                    mimetype="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                )
        except Exception as e:
            download_link = mo.md(f"**Error creating Excel file:** {str(e)}")

    return (download_link,)


