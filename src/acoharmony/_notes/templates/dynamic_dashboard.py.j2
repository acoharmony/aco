@app.function(hide_code=True)
def analyze_schema():
    """Analyze the dataframe schema using Polars introspection."""
    if df_main.height == 0:
        return {
            'numeric_cols': [],
            'categorical_cols': [],
            'date_cols': [],
            'boolean_cols': [],
            'high_cardinality_cols': [],
            'low_cardinality_cols': [],
            'suitable_filter_cols': [],
            'nullable_cols': [],
            'schema': {}
        }

    # Get schema information
    schema_info = {}
    numeric_cols = []
    categorical_cols = []
    date_cols = []
    boolean_cols = []
    high_cardinality_cols = []
    low_cardinality_cols = []
    suitable_filter_cols = []
    nullable_cols = []

    # Patterns that indicate a column shouldn't be used for filtering
    bad_filter_patterns = [
        'address', 'line_1', 'line_2', 'line_3', 'line_4', 'line_5', 'line_6',
        'street', 'description', 'note', 'comment', 'text', 'message',
        'id', 'key', 'uuid', 'guid', 'hash'
    ]

    # Patterns that indicate good filter candidates
    good_filter_patterns = [
        'state', 'status', 'type', 'category', 'gender', 'race',
        'ethnicity', 'county', 'provider', 'enrollment', 'flag',
        'year', 'month', 'quarter'
    ]

    # Analyze each column
    for col_name in df_main.columns:
        dtype = df_main[col_name].dtype
        col_lower = col_name.lower()

        # Check for nulls
        null_count = df_main[col_name].null_count()
        if null_count > 0:
            nullable_cols.append(col_name)

        # Categorize by dtype
        if dtype in [pl.Int8, pl.Int16, pl.Int32, pl.Int64,
                     pl.UInt8, pl.UInt16, pl.UInt32, pl.UInt64,
                     pl.Float32, pl.Float64, pl.Decimal]:
            numeric_cols.append(col_name)
        elif dtype == pl.Boolean:
            boolean_cols.append(col_name)
        elif dtype in [pl.Date, pl.Datetime, pl.Duration, pl.Time]:
            date_cols.append(col_name)
        elif dtype in [pl.Utf8, pl.Categorical, pl.String]:
            categorical_cols.append(col_name)

            # Check cardinality for categorical columns
            n_unique = df_main[col_name].n_unique()

            # Skip columns with too many nulls or all same value
            non_null_ratio = 1 - (null_count / df_main.height) if df_main.height > 0 else 0

            if n_unique <= 20 and n_unique > 1 and non_null_ratio > 0.5:
                low_cardinality_cols.append(col_name)

                # Check if it's suitable for filtering
                is_bad = any(bad in col_lower for bad in bad_filter_patterns)
                is_good = any(good in col_lower for good in good_filter_patterns)

                # Add to suitable filters if it's good or at least not bad
                if is_good or (not is_bad and n_unique <= 10):
                    suitable_filter_cols.append(col_name)

            elif n_unique > 100:
                high_cardinality_cols.append(col_name)

        schema_info[col_name] = {
            'dtype': str(dtype),
            'null_count': null_count,
            'n_unique': df_main[col_name].n_unique()
        }

    return {
        'numeric_cols': numeric_cols,
        'categorical_cols': categorical_cols,
        'date_cols': date_cols,
        'boolean_cols': boolean_cols,
        'high_cardinality_cols': high_cardinality_cols,
        'low_cardinality_cols': low_cardinality_cols,
        'suitable_filter_cols': suitable_filter_cols,
        'nullable_cols': nullable_cols,
        'schema': schema_info
    }


