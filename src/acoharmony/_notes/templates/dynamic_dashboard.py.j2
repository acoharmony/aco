@app.function(hide_code=True)
def create_dynamic_filters(mo):
    """Create filters dynamically based on column dtypes and suitability."""
    if df_main.height == 0:
        return {"controls": mo.md("**No data to filter**"), "filters": {}}

    schema_analysis = analyze_schema()
    filters = {}

    # Check for identifier columns (MBI, NPI, etc.) that need search boxes
    identifier_patterns = ['mbi', 'npi', 'hic', 'beneficiary_id', 'patient_id', 'provider_id', 'tin', 'member_id']
    search_cols = []

    for col in df_main.columns:
        col_lower = col.lower()
        # Check if it matches identifier patterns and has reasonable cardinality
        if any(pattern in col_lower for pattern in identifier_patterns):
            n_unique = df_main[col].n_unique()
            # Only add search if there are multiple unique values
            if n_unique > 1 and n_unique < df_main.height:  # Not all unique, not all same
                search_cols.append(col)
                if len(search_cols) >= 2:  # Limit to 2 search boxes
                    break

    # Create search boxes for identifiers
    for col in search_cols:
        filters[col] = mo.ui.text(
            placeholder=f"Search {col.replace('_', ' ').title()}...",
            label=f"🔍 {col.replace('_', ' ').title()}"
        )

    # Use suitable_filter_cols first, then fall back to low_cardinality_cols
    filter_candidates = schema_analysis['suitable_filter_cols']
    if not filter_candidates:
        # Fallback to low cardinality columns that aren't obviously bad
        filter_candidates = [
            col for col in schema_analysis['low_cardinality_cols']
            if not any(bad in col.lower() for bad in ['address', 'line_', 'id'])
        ]

    # Create dropdowns for suitable categorical columns
    dropdown_count = 0
    max_dropdowns = 5 - len(search_cols)  # Adjust limit based on search boxes

    for col in filter_candidates:
        if dropdown_count >= max_dropdowns:
            break

        unique_vals = df_main[col].unique().drop_nulls().to_list()
        if unique_vals and len(unique_vals) > 1:  # Only if there's something to filter
            filters[col] = mo.ui.dropdown(
                options=["All"] + sorted(unique_vals),
                value="All",
                label=col.replace('_', ' ').title()
            )
            dropdown_count += 1

    # Create range sliders for important numeric columns
    numeric_filter_cols = [
        col for col in schema_analysis['numeric_cols']
        if any(x in col.lower() for x in ['amount', 'cost', 'spend', 'total', 'count'])
    ][:3]  # Limit to 3 sliders

    for col in numeric_filter_cols:
        min_val = df_main[col].min()
        max_val = df_main[col].max()
        if min_val is not None and max_val is not None:
            filters[col] = mo.ui.range_slider(
                start=float(min_val),
                stop=float(max_val),
                step=float((max_val - min_val) / 100),
                value=[float(min_val), float(max_val)],
                label=col.replace('_', ' ').title()
            )

    # Create date range for date columns
    for col in schema_analysis['date_cols'][:2]:  # Limit to 2 date ranges
        min_date = df_main[col].min()
        max_date = df_main[col].max()
        if min_date and max_date:
            filters[col] = mo.ui.date_range(
                start=min_date,
                stop=max_date,
                label=col.replace('_', ' ').title()
            )

    if filters:
        # Arrange filters in rows
        filter_widgets = list(filters.values())
        filter_rows = []

        # Group widgets into rows of 3
        for i in range(0, len(filter_widgets), 3):
            row_widgets = filter_widgets[i:i+3]
            if row_widgets:
                filter_rows.append(mo.hstack(row_widgets, gap=1))

        filter_controls = mo.vstack([
            create_section_header("🔍 Filter Controls", "#6366F1", "#8B5CF6"),
            *filter_rows
        ], gap=0.5)
    else:
        filter_controls = mo.md("**No suitable columns for filtering found**")

    return {"controls": filter_controls, "filters": filters}


@app.cell(hide_code=True)
def _(filters, mo):
    """Create a smart data table with filtering."""
    if df_main.height == 0:
        data_table = mo.md("**No data to display**")
        filtered_df = df_main
    else:
        # Apply filters
        filtered_df = df_main

        for col_name, filter_widget in filters.items():
            if hasattr(filter_widget, 'value'):
                value = filter_widget.value

                # Handle text search (for MBI, NPI, etc.)
                if hasattr(filter_widget, '_tag') and 'text' in str(type(filter_widget)):
                    if value and value.strip():
                        # Use contains for partial matching
                        filtered_df = filtered_df.filter(
                            pl.col(col_name).str.contains(value.strip(), literal=True)
                        )

                # Handle dropdown filters
                elif hasattr(filter_widget, '_tag') and 'dropdown' in str(type(filter_widget)):
                    if value != "All":
                        filtered_df = filtered_df.filter(pl.col(col_name) == value)

                # Handle range sliders
                elif hasattr(filter_widget, '_tag') and 'range_slider' in str(type(filter_widget)):
                    if value:
                        filtered_df = filtered_df.filter(
                            (pl.col(col_name) >= value[0]) & (pl.col(col_name) <= value[1])
                        )

                # Handle date ranges
                elif hasattr(filter_widget, '_tag') and 'date_range' in str(type(filter_widget)):
                    if value and len(value) == 2:
                        filtered_df = filtered_df.filter(
                            (pl.col(col_name) >= value[0]) & (pl.col(col_name) <= value[1])
                        )

        # Determine which columns to show
        schema_analysis = analyze_schema()

        # Prioritize columns for display
        display_cols = []

        # Add primary key if specified
        {% if config.primary_key %}
        if "{{ config.primary_key }}" in df_main.columns:
            display_cols.append("{{ config.primary_key }}")
        {% endif %}

        # Add important categorical columns
        for col in schema_analysis['low_cardinality_cols'][:3]:
            if col not in display_cols:
                display_cols.append(col)

        # Add important numeric columns
        important_numeric = [
            col for col in schema_analysis['numeric_cols']
            if any(x in col.lower() for x in ['amount', 'cost', 'spend', 'total'])
        ][:3]
        display_cols.extend([c for c in important_numeric if c not in display_cols])

        # Add date columns
        display_cols.extend([c for c in schema_analysis['date_cols'][:2] if c not in display_cols])

        # Ensure we have some columns to display
        if not display_cols:
            display_cols = df_main.columns[:10]

        # Select and sort
        display_df = filtered_df.select([c for c in display_cols if c in filtered_df.columns])

        {% if config.default_sort_column %}
        if "{{ config.default_sort_column }}" in display_df.columns:
            display_df = display_df.sort("{{ config.default_sort_column }}", descending=True)
        {% endif %}

        # Limit rows
        display_df = display_df.head({{ config.max_display_rows }})

        # Create table with stats
        table_title = "## 📊 Data Table"

        # Add dynamic title based on content
        if any('patient' in col.lower() or 'bene' in col.lower() for col in display_cols):
            table_title = "## 👥 Patient Data"
        elif any('provider' in col.lower() for col in display_cols):
            table_title = "## 🏥 Provider Data"
        elif any('claim' in col.lower() for col in display_cols):
            table_title = "## 📋 Claims Data"

        table_html = f"""
        {table_title}

        <div style="padding: 0.75rem; background: #F3F4F6; border-left: 4px solid #6B7280; margin: 1rem 0;">
            <p style="margin: 0; color: #374151; font-size: 0.9rem;">
                Showing <strong>{min(display_df.height, {{ config.max_display_rows }})}</strong> of <strong>{filtered_df.height:,}</strong> filtered records
                (Total dataset: {df_main.height:,} records)
            </p>
        </div>
        """

        table_widget = mo.ui.table(
            display_df.to_dicts(),
            pagination=True,
            page_size=25,
            selection=None,
            show_column_summaries=True
        )

        data_table = mo.vstack([
            mo.md(table_html),
            table_widget
        ])

    return (data_table, filtered_df)


