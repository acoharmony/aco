#!/usr/bin/env bash
# Drop-in shim for `4icli` that persists the resulting config.txt back
# to the workspace source of truth ($BRONZE/config.txt) after any
# subcommand that mutates credentials.
#
# Without this, `4icli rotate` writes the new creds to
# $HOME/.config/4icli/config.txt inside the container, but the
# container entrypoint reseeds from $BRONZE/config.txt on next start —
# so the rotation gets silently undone. Same problem for `4icli configure`.
#
# Installation: this file is copied into the image at /usr/local/bin/4icli
# and the real Go binary is renamed to /usr/local/bin/4icli-bin. Every
# caller (Python wrapper, manual `docker exec -it 4icli 4icli rotate`,
# anything else) hits this shim transparently.
set -euo pipefail

REAL_4ICLI="/usr/local/bin/4icli-bin"
CONFIG_FILE="${HOME}/.config/4icli/config.txt"
WORKSPACE_CONFIG="/opt/s3/data/workspace/bronze/config.txt"

pre_sha=""
[ -s "$CONFIG_FILE" ] && pre_sha=$(sha256sum "$CONFIG_FILE" | awk '{print $1}')

set +e
"$REAL_4ICLI" "$@"
rc=$?
set -e

case "${1:-}" in
    rotate|configure)
        if [ "$rc" -eq 0 ] && [ -s "$CONFIG_FILE" ]; then
            post_sha=$(sha256sum "$CONFIG_FILE" | awk '{print $1}')
            if [ "$pre_sha" != "$post_sha" ]; then
                cp "$CONFIG_FILE" "$WORKSPACE_CONFIG"
                chmod 644 "$WORKSPACE_CONFIG"
                echo "[4icli] persisted rotated config -> $WORKSPACE_CONFIG" >&2
            fi
        fi
        ;;
esac

exit "$rc"
