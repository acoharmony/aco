#!/usr/bin/env bash
# Pre-commit hook: ruff lint/format + ty → targeted tests → 100% coverage
# Version-controlled in .githooks/ — activate with:
#   git config core.hooksPath .githooks
set -euo pipefail

# ── Branch Protection ────────────────────────────────────────────────────
# Prevent direct commits to main branch
branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "$branch" = "main" ]; then
  echo "❌ ERROR: Direct commits to 'main' branch are not allowed!"
  echo ""
  echo "Please create a feature branch first:"
  echo "  git checkout -b feature/your-feature-name"
  echo ""
  exit 1
fi

STATE_DIR=".test-state"
mkdir -p "$STATE_DIR"

# ── Helpers ──────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${GREEN}[pre-commit]${NC} $*"; }
warn()  { echo -e "${YELLOW}[pre-commit]${NC} $*"; }
fail()  { echo -e "${RED}[pre-commit]${NC} $*"; exit 1; }

# Collect staged .py files (excludes deletes)
mapfile -t STAGED_PY < <(git diff --cached --name-only --diff-filter=d -- '*.py')

if [ ${#STAGED_PY[@]} -eq 0 ]; then
    info "No Python files staged — skipping."
    exit 0
fi

# ── Stage 1: Ruff check + format + ty ───────────────────────────────────
info "Running ruff check on ${#STAGED_PY[@]} staged files..."
if ! uv run ruff check --fix "${STAGED_PY[@]}"; then
    fail "ruff check failed. Fix errors before committing."
fi

info "Running ruff format on staged files..."
uv run ruff format "${STAGED_PY[@]}"

# Re-stage any files that ruff modified
for f in "${STAGED_PY[@]}"; do
    if [ -f "$f" ]; then
        git add "$f"
    fi
done

# Run ty type checking on staged source files
SRC_PY=()
for f in "${STAGED_PY[@]}"; do
    if [[ "$f" == src/* ]]; then
        SRC_PY+=("$f")
    fi
done
if [ ${#SRC_PY[@]} -gt 0 ]; then
    info "Running ty check on ${#SRC_PY[@]} staged source files..."
    if ! uv run ty check "${SRC_PY[@]}"; then
        fail "ty check failed. Fix type errors before committing."
    fi
fi

# ── Stage 2: Auto-discover module→test mappings via Python ──────────────
# Outputs JSON: {"modules": {"mod": {"test_dir": "...", "cov": "...", "files": [...]}}}
MAPPING_JSON=$(python3 -c "
import json, os, sys

staged = sys.argv[1:]
result = {}

for f in staged:
    if not f.startswith('src/acoharmony/'):
        continue

    rel = f[len('src/acoharmony/'):]

    # Subpackage file: src/acoharmony/_parsers/_csv.py → mod=_parsers
    if '/' in rel:
        mod = rel.split('/')[0]
        cov = f'acoharmony.{mod}'
    else:
        # Root-level file: config.py → mod=config
        mod = rel.removesuffix('.py')
        cov = f'acoharmony.{mod}'

    # Auto-discover test directory by scanning tests/ for matching dirs
    # Convention: tests/{mod}/ or tests/_{mod}/ or tests/{mod.lstrip('_')}/
    test_dir = None
    candidates = [
        f'tests/{mod}',
        f'tests/_{mod}' if not mod.startswith('_') else None,
        f'tests/{mod.lstrip(\"_\")}' if mod.startswith('_') else None,
    ]
    # Special cases that can't be auto-discovered
    if mod in ('__main__', 'cli'):
        candidates = ['tests/_cli']
    elif mod == '__init__':
        candidates = ['tests']

    for c in candidates:
        if c and os.path.isdir(c):
            test_dir = c
            break

    if test_dir is None:
        continue

    if mod not in result:
        result[mod] = {'test_dir': test_dir, 'cov': cov, 'files': []}
    result[mod]['files'].append(f)

print(json.dumps(result))
" "${STAGED_PY[@]}" 2>/dev/null || echo "{}")

if [ "$MAPPING_JSON" = "{}" ]; then
    # No source modules matched — check for test-only changes
    has_tests=false
    test_files=()
    for f in "${STAGED_PY[@]}"; do
        if [[ "$f" == tests/* ]]; then
            has_tests=true
            test_files+=("$f")
        fi
    done

    if [ "$has_tests" = true ]; then
        info "Only test files changed — running changed tests..."
        uv run pytest "${test_files[@]}" -x --no-header -q || fail "Tests failed."
        info "All tests passed."
    else
        info "No source or test files to test — skipping."
    fi
    exit 0
fi

# ── Stage 3: State check + per-module test loop (fail fast) ─────────────
# For each module: check state → skip if green → test → require 100% → record state
# Fail immediately on first module that doesn't reach 100%.

COVRC=$(mktemp)
cat > "$COVRC" <<'COVEOF'
[run]
branch = true
parallel = true
data_file = .test-state/.coverage
omit =
    */test_*
    */_dev/*
    */_docs/*

[report]
exclude_lines =
    no cov
    pragma: no cover
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    raise NotImplementedError
    \.\.\.
COVEOF

# Parse modules from JSON and process each
MODULES=$(echo "$MAPPING_JSON" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for mod in data:
    d = data[mod]
    print(f\"{mod}|{d['test_dir']}|{d['cov']}|{' '.join(d['files'])}\")
")

any_tested=false
all_green=true

while IFS='|' read -r mod test_dir cov_mod files; do
    [ -z "$mod" ] && continue

    # Compute source hash from staged content
    current_hash=""
    for sf in $files; do
        current_hash+="$(git show ":$sf" 2>/dev/null | sha256sum)"
    done
    current_hash=$(echo "$current_hash" | sha256sum | cut -d' ' -f1)

    state_hash="$STATE_DIR/${mod}.hash"
    state_cov="$STATE_DIR/${mod}.cov"

    # Skip if hash matches AND 0 missing statements
    if [ -f "$state_hash" ] && [ -f "$state_cov" ] \
       && [ "$(cat "$state_hash")" = "$current_hash" ] \
       && [ "$(cat "$state_cov")" = "0" ]; then
        info "Module $cov_mod: unchanged + 100% covered — skip."
        continue
    fi

    any_tested=true
    info "Testing module $cov_mod → $test_dir"

    cov_json="$STATE_DIR/_run_${mod}.json"

    if COVERAGE_RCFILE="$COVRC" uv run pytest "$test_dir" \
        -x --no-header -q \
        --cov="$cov_mod" \
        --cov-report=term-missing:skip-covered \
        --cov-report="json:$cov_json" \
        --cov-fail-under=100; then

        # Green: record state
        echo "$current_hash" > "$state_hash"

        # Count missing from JSON
        missing=$(python3 -c "
import json
with open('$cov_json') as f:
    data = json.load(f)
total = 0
for path, info in data.get('files', {}).items():
    if path.startswith('src/acoharmony/${mod}'):
        total += len(info.get('missing_lines', []))
        total += len(info.get('missing_branches', []))
print(total)
" 2>/dev/null || echo "-1")

        echo "$missing" > "$state_cov"
        rm -f "$cov_json"

        if [ "$missing" != "0" ]; then
            rm -f "$COVRC"
            fail "Module $cov_mod: $missing uncovered statements/branches. Fix before committing."
        fi

        info "Module $cov_mod: 100% covered."
    else
        # Red: invalidate state, stop everything
        rm -f "$state_hash" "$state_cov" "$cov_json" "$COVRC"
        fail "Module $cov_mod: tests failed or coverage < 100%. Stopping."
    fi

done <<< "$MODULES"

rm -f "$COVRC"

if [ "$any_tested" = true ]; then
    info "All changed modules passed with 100% statement coverage."
else
    info "All modules unchanged and already at 100% — nothing to test."
fi
